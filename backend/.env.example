# =============================================================================
# Portal Summer — Environment Variables Template
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values
# 3. Never commit .env to git
# =============================================================================


# -----------------------------------------------------------------------------
# Core Django settings
# -----------------------------------------------------------------------------

# Secret key — must be unique and kept secret in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here

# Debug mode — set to False in production!
DEBUG=True

# Comma-separated list of allowed hosts.
# Example for production: ALLOWED_HOSTS=mysite.ru,www.mysite.ru
ALLOWED_HOSTS=localhost,127.0.0.1


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Option 1: DATABASE_URL — single variable, takes priority over everything else.
#           Recommended for production and PaaS (Railway, Render, Heroku).
#           Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/portal_summer

# Option 2: Individual variables.
#           USE_SQLITE=True  → SQLite (no PostgreSQL needed, good for local dev)
#           USE_SQLITE=False → PostgreSQL using variables below
USE_SQLITE=True
POSTGRES_DB=portal_summer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Keep DB connections alive for N seconds (0 = close after each request)
DB_CONN_MAX_AGE=60


# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------

# Frontend origin(s) allowed to call the API.
# Example for production: CORS_ALLOWED_ORIGINS=https://mysite.ru
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# -----------------------------------------------------------------------------
# Email (Yandex SMTP)
# -----------------------------------------------------------------------------

# Yandex account address used as sender.
EMAIL_HOST_USER=your-email@yandex.ru

# App password (not your regular Yandex password).
# Create at: https://id.yandex.ru/security/app-passwords
EMAIL_HOST_PASSWORD=your-app-password


# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------

# Base URL of the frontend — used in confirmation emails sent to users.
# Example for production: FRONTEND_URL=https://mysite.ru
FRONTEND_URL=http://localhost:3000
